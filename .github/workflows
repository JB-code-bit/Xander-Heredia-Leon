name: Portfolio Upload

on:
workflow_dispatch:

jobs:
upload:
runs-on: ubuntu-latest

```
steps:
  - name: Checkout repo
    uses: actions/checkout@v3

  - name: Commit changes
    run: |
      git config user.name "Portfolio Bot"
      git config user.email "bot@github.com"
      git add .
      git commit -m "Upload new photos" || echo "No changes"
      git push
    env:
      GITHUB_TOKEN: ${{ secrets.GH_UPLOAD_TOKEN }}
```
